# Normalize line endings
* text=auto

# Force LF for text files
*.js    text eol=lf
*.ts    text eol=lf
*.py    text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.sh    text eol=lf
*.css   text eol=lf
*.html  text eol=lf

# Binary files
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.pdf   binary
